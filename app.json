{
  "expo": {
    "name": "Out North East",
    "slug": "outnortheast",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1140"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      },
      "bundleIdentifier": "org.outnortheast.app"
    },
    "android": {
      "package": "org.outnortheast.app",
      "permissions": [
        "FOREGROUND_SERVICE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1140"
      }
    },
    "plugins": [
      "expo-notifications",
      "expo-font",
      "expo-status-bar"
    ]
  }
}
